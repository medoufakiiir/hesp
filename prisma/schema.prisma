generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ---------- Contact Messages ----------
enum MessageStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  subject   String?
  body      String        @db.Text
  status    MessageStatus @default(NEW)
  locale    String        @default("en")
  createdAt DateTime      @default(now())
  readAt    DateTime?
}

// ---------- Users / Auth (RBAC) ----------
enum UserRole {
  SUPER_ADMIN
  MANAGER
  SALES
  MARKETING
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(SALES)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quotesCreated  Quote[] @relation("CreatedBy")
  quotesAssigned Quote[] @relation("AssignedTo")
}

// ---------- Catalog ----------
model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  nameEn    String
  nameAr    String
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  parts     Part[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Brand {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameEn    String
  nameAr    String
  logoUrl   String?
  parts     Part[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EquipmentModel {
  id        String              @id @default(cuid())
  make      String              // e.g. Caterpillar
  model     String              // e.g. 320D
  year      String?
  parts     PartCompatibility[]
  createdAt DateTime            @default(now())

  @@unique([make, model, year])
}

model Part {
  id            String              @id @default(cuid())
  sku           String              @unique
  oemNumber     String?
  nameEn        String
  nameAr        String
  descriptionEn String?             @db.Text
  descriptionAr String?             @db.Text
  categoryId    String
  category      Category            @relation(fields: [categoryId], references: [id])
  brandId       String?
  brand         Brand?              @relation(fields: [brandId], references: [id])
  listPrice     Decimal?            @db.Decimal(12, 2) // SAR reference price (optional)
  stockQty      Int                 @default(0)
  isActive      Boolean             @default(true)
  images        PartImage[]
  compatibility PartCompatibility[]
  quoteItems    QuoteItem[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model PartImage {
  id     String @id @default(cuid())
  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)
  url    String
  alt    String?
  sort   Int    @default(0)
}

model PartCompatibility {
  partId           String
  part             Part           @relation(fields: [partId], references: [id], onDelete: Cascade)
  equipmentModelId String
  equipmentModel   EquipmentModel @relation(fields: [equipmentModelId], references: [id], onDelete: Cascade)

  @@id([partId, equipmentModelId])
}

// ---------- Customers (B2B companies) ----------
model Company {
  id          String    @id @default(cuid())
  name        String
  crNumber    String?   // Commercial Registration
  vatNumber   String?   // KSA VAT
  email       String?
  phone       String?
  addressLine String?
  city        String?
  country     String    @default("SA")
  notes       String?   @db.Text
  contacts    Contact[]
  quotes      Quote[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Contact {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  position  String?
  isPrimary Boolean @default(false)
}

// ---------- Quotes / RFQ ----------
enum QuoteStatus {
  SUBMITTED  // RFQ received
  REVIEWING
  QUOTED     // pricing sent to customer
  CONFIRMED  // customer accepted
  INVOICED
  COMPLETED
  REJECTED
  CANCELLED
  EXPIRED
}

model Quote {
  id           String      @id @default(cuid())
  number       String      @unique // RFQ-2026-0001
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  status       QuoteStatus @default(SUBMITTED)
  currency     String      @default("SAR")
  customerNote String?     @db.Text
  internalNote String?     @db.Text
  vatRate      Decimal     @default(15) @db.Decimal(5, 2)
  subtotal     Decimal     @default(0) @db.Decimal(12, 2)
  vatAmount    Decimal     @default(0) @db.Decimal(12, 2)
  total        Decimal     @default(0) @db.Decimal(12, 2)
  validUntil   DateTime?
  createdById  String?
  createdBy    User?       @relation("CreatedBy", fields: [createdById], references: [id])
  assignedToId String?
  assignedTo   User?       @relation("AssignedTo", fields: [assignedToId], references: [id])
  items        QuoteItem[]
  invoice      Invoice?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  partId      String?
  part        Part?   @relation(fields: [partId], references: [id])
  description String? // free-text when part not in catalog
  quantity    Int     @default(1)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal @default(0) @db.Decimal(12, 2)
}

// ---------- Invoice (offline) ----------
enum InvoiceStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  VOID
}

model Invoice {
  id         String        @id @default(cuid())
  number     String        @unique // INV-2026-0001
  quoteId    String        @unique
  quote      Quote         @relation(fields: [quoteId], references: [id])
  status     InvoiceStatus @default(UNPAID)
  issuedAt   DateTime      @default(now())
  dueAt      DateTime?
  paidAt     DateTime?
  amountPaid Decimal       @default(0) @db.Decimal(12, 2)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

// ---------- Blog ----------
model BlogPost {
  id             String    @id @default(cuid())
  slug           String    @unique
  titleEn        String
  titleAr        String
  excerptEn      String?
  excerptAr      String?
  bodyEn         String    @db.Text
  bodyAr         String    @db.Text
  coverImageUrl  String?
  metaTitleEn    String?
  metaTitleAr    String?
  metaDescEn     String?
  metaDescAr     String?
  primaryKeyword String?
  keywords       String[]
  published      Boolean   @default(false)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ---------- Website Analytics ----------
model PageView {
  id        String   @id @default(cuid())
  path      String
  visitorId String // anonymous, cookie-based unique-visitor id
  referrer  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([visitorId])
}

