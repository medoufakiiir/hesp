generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ── Auth ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  role          String    @default("super_admin") // super_admin | manager | sales
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Business Data ──

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  nameEN        String
  nameAR        String
  descriptionEN String
  descriptionAR String
  category      String
  brand         String
  image         String
  partNumber    String
  inStock       Boolean  @default(true)
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([brand])
  @@index([featured])
}

model Category {
  id            String   @id
  slug          String   @unique
  nameEN        String
  nameAR        String
  descriptionEN String   @db.Text
  descriptionAR String   @db.Text
  image         String
  icon          String
  metaTitleEN   String
  metaTitleAR   String
  metaDescEN    String   @db.Text
  metaDescAR    String   @db.Text
  keywordsEN    String[]
  keywordsAR    String[]
  productCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Brand {
  id            String   @id
  slug          String   @unique
  name          String
  nameAR        String
  descriptionEN String   @db.Text
  descriptionAR String   @db.Text
  country       String
  founded       String
  metaTitleEN   String
  metaTitleAR   String
  metaDescEN    String   @db.Text
  metaDescAR    String   @db.Text
  categories    String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleEN     String
  titleAR     String
  excerptEN   String   @db.Text
  excerptAR   String   @db.Text
  contentEN   String   @db.Text
  contentAR   String   @db.Text
  image       String
  date        String
  author      String
  tags        String[]
  metaTitleEN String
  metaTitleAR String
  metaDescEN  String   @db.Text
  metaDescAR  String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inquiry {
  id         String   @id @default(cuid())
  name       String
  company    String   @default("")
  phone      String
  email      String   @default("")
  part       String   @default("")
  category   String   @default("")
  brand      String   @default("")
  partNumber String   @default("")
  quantity   String   @default("1")
  details    String   @default("") @db.Text
  status     String   @default("new")
  source     String   @default("quote")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
